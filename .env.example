# Arquivo de Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NÃO commite .env no repositório (adicione ao .gitignore)

# ============================================================================
# BANCO DE DADOS KAMAILIO (PostgreSQL)
# ============================================================================
KAMAILIO_DB_HOST=localhost
KAMAILIO_DB_PORT=5432
KAMAILIO_DB_NAME=kamailio
KAMAILIO_DB_USER=kamailio
KAMAILIO_DB_PASSWORD=sua_senha_aqui

# ============================================================================
# ZABBIX API
# ============================================================================
ZABBIX_URL=http://seu-zabbix.com/api_jsonrpc.php

# Opção 1: Autenticação com Token API (recomendado - mais seguro)
ZABBIX_API_TOKEN=seu_token_api_zabbix

# Opção 2: Autenticação com Usuário/Senha (legado - deixe vazio se usar token)
ZABBIX_USER=seu_usuario_zabbix
ZABBIX_PASSWORD=sua_senha_zabbix

# Nome do grupo onde os hosts serão criados
ZABBIX_GROUP_NAME=Ramais UNIMED

# Nome do template a ser vinculado
ZABBIX_TEMPLATE_NAME=ICMP Ping

# ============================================================================
# LOGGING
# ============================================================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=kamailio_zabbix_sync.log

# ============================================================================
# COMPORTAMENTO DO SCRIPT
# ============================================================================
# Se True, apenas simula a sincronização (dry-run)
DRY_RUN=False

# Se True, cria hosts automaticamente. Se False, apenas lista diferenças
AUTO_CREATE_HOSTS=True

# Se True, atualiza IPs de hosts existentes
AUTO_UPDATE_IPS=True

# Intervalo mínimo entre sincronizações (em segundos)
SYNC_INTERVAL=300
